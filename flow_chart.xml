<mxfile>
  <diagram name="Flowchart">
    <mxGraphModel>
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Start -->
        <mxCell id="start" value="Start" style="ellipse;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="100" height="50" as="geometry"/>
        </mxCell>

        <!-- Trigger -->
        <mxCell id="trigger" value="Trigger Scan (API / Scheduler)" style="rectangle;" vertex="1" parent="1">
          <mxGeometry x="250" y="100" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Ingestion -->
        <mxCell id="ingest" value="Log Ingestion (Local + CloudWatch)" style="rectangle;" vertex="1" parent="1">
          <mxGeometry x="250" y="190" width="220" height="60" as="geometry"/>
        </mxCell>

        <!-- Detection -->
        <mxCell id="detect" value="Run Detection Tools (System, Network, File)" style="rectangle;" vertex="1" parent="1">
          <mxGeometry x="230" y="280" width="260" height="60" as="geometry"/>
        </mxCell>

        <!-- Decision -->
        <mxCell id="decision" value="Threats Found?" style="rhombus;" vertex="1" parent="1">
          <mxGeometry x="280" y="370" width="140" height="80" as="geometry"/>
        </mxCell>

        <!-- No path -->
        <mxCell id="no" value="Store Result (No Threats)" style="rectangle;" vertex="1" parent="1">
          <mxGeometry x="100" y="480" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Yes path -->
        <mxCell id="phase2" value="Phase 2: Intelligence Pipeline" style="rectangle;" vertex="1" parent="1">
          <mxGeometry x="380" y="480" width="220" height="60" as="geometry"/>
        </mxCell>

        <!-- Parallel -->
        <mxCell id="parallel" value="Parallel: Threat + Vulnerability Analysis" style="rectangle;" vertex="1" parent="1">
          <mxGeometry x="360" y="580" width="260" height="60" as="geometry"/>
        </mxCell>

        <!-- Merge -->
        <mxCell id="merge" value="Merge Results" style="rectangle;" vertex="1" parent="1">
          <mxGeometry x="380" y="670" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Final -->
        <mxCell id="final" value="Generate Report + Risk Score" style="rectangle;" vertex="1" parent="1">
          <mxGeometry x="360" y="760" width="240" height="60" as="geometry"/>
        </mxCell>

        <!-- Alerts -->
        <mxCell id="alert" value="Send Slack Alert (HIGH/CRITICAL)" style="rectangle;" vertex="1" parent="1">
          <mxGeometry x="360" y="850" width="240" height="60" as="geometry"/>
        </mxCell>

        <!-- End -->
        <mxCell id="end" value="End" style="ellipse;" vertex="1" parent="1">
          <mxGeometry x="320" y="950" width="100" height="50" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell edge="1" parent="1" source="start" target="trigger"/>
        <mxCell edge="1" parent="1" source="trigger" target="ingest"/>
        <mxCell edge="1" parent="1" source="ingest" target="detect"/>
        <mxCell edge="1" parent="1" source="detect" target="decision"/>

        <mxCell edge="1" parent="1" source="decision" target="no">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" parent="1" source="decision" target="phase2"/>
        <mxCell edge="1" parent="1" source="phase2" target="parallel"/>
        <mxCell edge="1" parent="1" source="parallel" target="merge"/>
        <mxCell edge="1" parent="1" source="merge" target="final"/>
        <mxCell edge="1" parent="1" source="final" target="alert"/>
        <mxCell edge="1" parent="1" source="alert" target="end"/>
        <mxCell edge="1" parent="1" source="no" target="end"/>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>